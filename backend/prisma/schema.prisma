generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  CLINIC_ADMIN
  PROVIDER
  STAFF
  PATIENT
}

enum AppointmentStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum VisitRecordStatus {
  DRAFT
  FINAL
}

enum TreatmentPlanStatus {
  ACTIVE
  COMPLETED
  DISCONTINUED
}

enum FormScope {
  CLINIC
  DISCIPLINE
  SERVICE
}

model Clinic {
  id               String   @id @default(cuid())
  name             String
  email            String
  subscriptionPlan String   @default("free")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users         User[]
  disciplines   Discipline[]
  providers     Provider[]
  locations     Location[]
  services      Service[]
  appointments    Appointment[]
  visitRecords    VisitRecord[]
  prescriptions   Prescription[]
  auditLogs       AuditLog[]
  waitlistEntries WaitlistEntry[]
  payments        Payment[]
  treatmentPlans  TreatmentPlan[]
  patientFiles    PatientFile[]
  formTemplates   FormTemplate[]
  formResponses   FormResponse[]
}

model User {
  id        String   @id @default(cuid())
  clinicId  String?
  name      String
  email     String   @unique
  password  String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic         Clinic?          @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  provider       Provider?
  refreshTokens   RefreshToken[]
  appointments    Appointment[]
  visitRecords    VisitRecord[]
  prescriptions   Prescription[]
  auditLogs       AuditLog[]
  waitlistEntries WaitlistEntry[]
  payments        Payment[]
  visitNoteVersions VisitNoteVersion[]
  treatmentPlans   TreatmentPlan[] @relation("PatientPlans")
  patientFiles     PatientFile[] @relation("PatientFiles")
  uploadedFiles    PatientFile[] @relation("UploadedFiles")
  formResponses    FormResponse[]
}

model Discipline {
  id          String   @id @default(cuid())
  clinicId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic         Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  providers      Provider[]
  services       Service[]
  treatmentPlans TreatmentPlan[]
  formTemplates  FormTemplate[]

  @@unique([clinicId, name])
}

model Provider {
  id            String   @id @default(cuid())
  clinicId      String
  userId        String?  @unique
  firstName     String
  lastName      String
  email         String?
  phone         String?
  disciplineId  String
  bufferMinutes Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clinic               Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  discipline           Discipline             @relation(fields: [disciplineId], references: [id], onDelete: Restrict)
  user                 User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  providerServices     ProviderService[]
  appointments         Appointment[]
  visitRecords        VisitRecord[]
  prescriptions       Prescription[]
  providerAvailability    ProviderAvailability[]
  providerUnavailability  ProviderUnavailability[]
  waitlistEntries         WaitlistEntry[]
  treatmentPlans          TreatmentPlan[]
}

model ProviderAvailability {
  id         String   @id @default(cuid())
  providerId String
  weekday    Int
  startTime  String
  endTime    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
}

model ProviderUnavailability {
  id         String    @id @default(cuid())
  providerId String
  date       DateTime
  startTime  String?
  endTime    String?
  reason     String?
  createdAt  DateTime  @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([date])
}

model Location {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  address   String?
  timezone  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic        Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
}

model Service {
  id                    String    @id @default(cuid())
  clinicId              String
  disciplineId          String
  name                  String
  duration              Int
  defaultPrice          Decimal   @db.Decimal(10, 2)
  taxApplicable         Boolean   @default(false)
  minimumNoticeMinutes  Int?      @default(0)
  maxFutureBookingDays  Int?      @default(365)
  cancellationWindowHours Int?    @default(0)
  cancellationFeeType  String?    @default("NONE")
  cancellationFeeValue Decimal?   @db.Decimal(10, 2)
  prepaymentType        String    @default("NONE") // NONE, DEPOSIT, FULL
  depositAmount         Decimal?  @db.Decimal(10, 2)
  requirePrepayment     Boolean   @default(false)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  clinic            Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  discipline        Discipline        @relation(fields: [disciplineId], references: [id], onDelete: Restrict)
  providerServices  ProviderService[]
  appointments      Appointment[]
  waitlistEntries   WaitlistEntry[]
  formTemplates     FormTemplate[]

  @@unique([clinicId, name])
  @@index([clinicId])
  @@index([disciplineId])
}

model ProviderService {
  id            String   @id @default(cuid())
  providerId    String
  serviceId     String
  priceOverride Decimal? @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([providerId, serviceId])
}

model Appointment {
  id                  String            @id @default(cuid())
  clinicId            String
  locationId          String
  providerId          String
  serviceId           String
  patientId           String
  startTime           DateTime
  endTime             DateTime
  status              AppointmentStatus @default(CONFIRMED)
  priceAtBooking      Decimal            @db.Decimal(10, 2)
  paymentStatus       String?            // NONE, PENDING, PAID
  paymentDueAt       DateTime?
  slotHeldUntil       DateTime?
  cancelledAt         DateTime?
  cancellationReason String?
  rescheduledFromId   String?    @unique
  rescheduledToId     String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  clinic   Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Restrict)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  patient  User     @relation(fields: [patientId], references: [id], onDelete: Restrict)

  rescheduledFrom Appointment? @relation("RescheduleFrom", fields: [rescheduledFromId], references: [id])
  rescheduledTo   Appointment? @relation("RescheduleFrom")

  visitRecords   VisitRecord[]
  prescriptions  Prescription[]
  payments       Payment[]
  formResponses  FormResponse[]

  @@index([providerId])
  @@index([patientId])
  @@index([clinicId])
  @@index([locationId])
  @@index([startTime])
  @@index([status])
}

model Payment {
  id            String   @id @default(cuid())
  clinicId      String
  appointmentId String
  patientId     String
  amount        Decimal  @db.Decimal(10, 2)
  status        String   // PENDING, SUCCESS, FAILED, REFUNDED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient     User        @relation(fields: [patientId], references: [id], onDelete: Restrict)

  @@index([appointmentId])
  @@index([status])
}

model VisitRecord {
  id                String            @id @default(cuid())
  clinicId          String
  appointmentId     String            @unique
  providerId        String
  patientId         String
  subjective        String?
  objective         String?
  assessment        String?
  plan              String?
  status            VisitRecordStatus @default(DRAFT)
  currentVersionId  String?  @unique
  isFinalized       Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  clinic         Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment    Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  provider       Provider          @relation(fields: [providerId], references: [id], onDelete: Restrict)
  patient        User              @relation(fields: [patientId], references: [id], onDelete: Restrict)
  versions       VisitNoteVersion[]
  currentVersion VisitNoteVersion?  @relation("CurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  patientFiles   PatientFile[]
}

model VisitNoteVersion {
  id             String   @id @default(cuid())
  visitRecordId  String
  subjective     String?
  objective      String?
  assessment     String?
  plan           String?
  createdAt      DateTime @default(now())
  createdById    String

  visitRecord       VisitRecord   @relation(fields: [visitRecordId], references: [id], onDelete: Cascade)
  createdBy         User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  currentForRecord  VisitRecord? @relation("CurrentVersion")

  @@index([visitRecordId])
}

model Prescription {
  id            String   @id @default(cuid())
  clinicId      String
  appointmentId String
  providerId    String
  patientId     String
  notes         String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  provider    Provider    @relation(fields: [providerId], references: [id], onDelete: Restrict)
  patient     User        @relation(fields: [patientId], references: [id], onDelete: Restrict)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id            String   @id @default(cuid())
  clinicId      String
  entityType    String
  entityId      String
  action        String
  fieldChanged  String?
  oldValue      Json?
  newValue      Json?
  performedById String
  createdAt     DateTime @default(now())

  clinic      Clinic @relation(fields: [clinicId], references: [id])
  performedBy User   @relation(fields: [performedById], references: [id])

  @@index([clinicId])
  @@index([entityType])
  @@index([entityId])
}

model WaitlistEntry {
  id                 String    @id @default(cuid())
  clinicId           String
  providerId         String
  serviceId         String
  patientId         String
  preferredDate     DateTime
  preferredStartTime String
  preferredEndTime   String
  status            String // WAITING, OFFERED, BOOKED, EXPIRED
  offeredAt         DateTime?
  expiresAt         DateTime?
  offeredStartTime  DateTime?
  offeredEndTime    DateTime?
  offeredLocationId String?
  createdAt         DateTime  @default(now())

  clinic   Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  patient  User     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([serviceId])
  @@index([status])
  @@index([patientId])
  @@index([clinicId])
}

model TreatmentPlan {
  id                String              @id @default(cuid())
  clinicId          String
  patientId         String
  providerId        String
  disciplineId      String
  name              String
  totalSessions     Int
  sessionsCompleted Int                 @default(0)
  startDate         DateTime
  endDate           DateTime?
  goals             Json?
  notes             String?
  status            TreatmentPlanStatus  @default(ACTIVE)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  clinic     Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient    User       @relation("PatientPlans", fields: [patientId], references: [id], onDelete: Restrict)
  provider   Provider   @relation(fields: [providerId], references: [id], onDelete: Restrict)
  discipline Discipline @relation(fields: [disciplineId], references: [id], onDelete: Restrict)

  @@index([patientId])
  @@index([providerId])
  @@index([clinicId])
}

model PatientFile {
  id             String    @id @default(cuid())
  clinicId       String
  patientId      String
  visitRecordId  String?
  uploadedById   String
  originalName   String
  storagePath    String
  mimeType       String
  size           Int
  tags           Json?
  isDeleted      Boolean   @default(false)
  createdAt      DateTime  @default(now())

  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     User         @relation("PatientFiles", fields: [patientId], references: [id], onDelete: Restrict)
  visitRecord VisitRecord? @relation(fields: [visitRecordId], references: [id], onDelete: SetNull)
  uploadedBy  User         @relation("UploadedFiles", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([patientId])
  @@index([clinicId])
  @@index([visitRecordId])
}

model FormTemplate {
  id           String    @id @default(cuid())
  clinicId     String
  name         String
  description  String?
  scope        FormScope
  disciplineId String?
  serviceId    String?
  fields       Json
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  discipline  Discipline?  @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  service     Service?     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  responses   FormResponse[]

  @@index([clinicId])
}

model FormResponse {
  id             String    @id @default(cuid())
  clinicId       String
  templateId     String
  patientId      String
  appointmentId  String?
  responses      Json
  createdAt      DateTime  @default(now())

  clinic      Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  template    FormTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  patient     User          @relation(fields: [patientId], references: [id], onDelete: Restrict)
  appointment Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([clinicId])
  @@index([templateId])
}
