generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  CLINIC_ADMIN
  PROVIDER
  STAFF
  PATIENT
}

enum AppointmentStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum VisitRecordStatus {
  DRAFT
  FINAL
}

model Clinic {
  id               String   @id @default(cuid())
  name             String
  email            String
  subscriptionPlan String   @default("free")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users         User[]
  disciplines   Discipline[]
  providers     Provider[]
  locations     Location[]
  services      Service[]
  appointments  Appointment[]
  visitRecords  VisitRecord[]
  prescriptions Prescription[]
  auditLogs     AuditLog[]
}

model User {
  id        String   @id @default(cuid())
  clinicId  String?
  name      String
  email     String   @unique
  password  String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic         Clinic?          @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  provider       Provider?
  refreshTokens  RefreshToken[]
  appointments   Appointment[]
  visitRecords   VisitRecord[]
  prescriptions  Prescription[]
  auditLogs     AuditLog[]
}

model Discipline {
  id          String   @id @default(cuid())
  clinicId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic    Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  providers Provider[]
  services  Service[]

  @@unique([clinicId, name])
}

model Provider {
  id           String   @id @default(cuid())
  clinicId     String
  userId       String?  @unique
  firstName    String
  lastName     String
  email        String?
  phone        String?
  disciplineId String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic            Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  discipline        Discipline       @relation(fields: [disciplineId], references: [id], onDelete: Restrict)
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  providerServices  ProviderService[]
  appointments      Appointment[]
  visitRecords      VisitRecord[]
  prescriptions     Prescription[]
}

model Location {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  address   String?
  timezone  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic        Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
}

model Service {
  id           String   @id @default(cuid())
  clinicId     String
  disciplineId String
  name         String
  duration     Int
  defaultPrice Decimal  @db.Decimal(10, 2)
  taxApplicable Boolean @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic            Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  discipline        Discipline        @relation(fields: [disciplineId], references: [id], onDelete: Restrict)
  providerServices  ProviderService[]
  appointments      Appointment[]

  @@unique([clinicId, name])
  @@index([clinicId])
  @@index([disciplineId])
}

model ProviderService {
  id            String   @id @default(cuid())
  providerId    String
  serviceId     String
  priceOverride Decimal? @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([providerId, serviceId])
}

model Appointment {
  id             String            @id @default(cuid())
  clinicId       String
  locationId     String
  providerId     String
  serviceId      String
  patientId      String
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus @default(CONFIRMED)
  priceAtBooking Decimal          @db.Decimal(10, 2)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  clinic   Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Restrict)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  patient  User     @relation(fields: [patientId], references: [id], onDelete: Restrict)

  visitRecords   VisitRecord[]
  prescriptions  Prescription[]

  @@index([providerId])
  @@index([patientId])
  @@index([clinicId])
  @@index([locationId])
  @@index([startTime])
  @@index([status])
}

model VisitRecord {
  id            String            @id @default(cuid())
  clinicId      String
  appointmentId String            @unique
  providerId    String
  patientId     String
  subjective    String?
  objective     String?
  assessment    String?
  plan          String?
  status        VisitRecordStatus @default(DRAFT)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  provider    Provider    @relation(fields: [providerId], references: [id], onDelete: Restrict)
  patient     User        @relation(fields: [patientId], references: [id], onDelete: Restrict)
}

model Prescription {
  id            String   @id @default(cuid())
  clinicId      String
  appointmentId String
  providerId    String
  patientId     String
  notes         String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  provider    Provider    @relation(fields: [providerId], references: [id], onDelete: Restrict)
  patient     User        @relation(fields: [patientId], references: [id], onDelete: Restrict)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id            String   @id @default(cuid())
  clinicId      String
  entityType    String
  entityId      String
  action        String
  fieldChanged  String?
  oldValue      Json?
  newValue      Json?
  performedById String
  createdAt     DateTime @default(now())

  clinic      Clinic @relation(fields: [clinicId], references: [id])
  performedBy User   @relation(fields: [performedById], references: [id])

  @@index([clinicId])
  @@index([entityType])
  @@index([entityId])
}
